# MongoDB Connection
MONGODB_URI=mongodb://usuario:password@host:27017/academicloud_logs?authSource=admin
MONGODB_DATABASE=academicloud_logs

# Server Configuration
PORT=3001

# Batch Processing (optimización de rendimiento)
BATCH_SIZE=100
BATCH_INTERVAL=500

# Notas:
# - BATCH_SIZE: Número máximo de logs en buffer antes de forzar escritura
# - BATCH_INTERVAL: Intervalo en milisegundos para escribir logs acumulados
# - Ajusta estos valores según tu carga (más alto = más throughput, menos tiempo real)

