{
  "name": "academicloud-logger",
  "version": "1.0.0",
  "description": "Microservicio de logging a MongoDB para AcademiCloud",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop academicloud-logger",
    "pm2:restart": "pm2 restart academicloud-logger",
    "pm2:logs": "pm2 logs academicloud-logger",
    "pm2:monit": "pm2 monit"
  },
  "keywords": [
    "mongodb",
    "logging",
    "microservice"
  ],
  "author": "AcademiCloud",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongodb": "^5.9.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
